// top level comment

import "https://example.com/baz.pkl"
import "package://example.com/myPackage@1.0.0#/Qux.pkl"
import "pkl:math"
import "pkl:reflect"

import "@bar/Bar.pkl"
import "@foo/Foo.pkl" as foo
import
  "@foo/Foo.pkl"
  as foo
  , {
    Bar,
    Baz as baz,
    Qux as quux,
    Quuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuux
      as
      quuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuuux,
  }
import "@foo/Foo.pkl" as { /* Bar */ Bar, Baz as baz /* baz */} // qux
import
  "@foo/Foo.pkl"
  as { /* 1 */ hello,
    world /* 2 */ , /* a */ a as b,
    b /* b */ as c,
    c as /* c */ d,
    d as e /* d */,
  } // quux

import "..."
import "module1.pkl"
// module2 leading
// module2 leading 2
import "module2.pkl"
/* module 11 leading */
import "module11.pkl" /* module11 block */ // trailing module11
import "Module12.pkl"

import* "file:///tmp/*.pkl"

import* "@foo/**.pkl"

import* "**.pkl" /* ** */ // glob import
