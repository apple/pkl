open module encoding1

import "pkl:encoding"
import "pkl:reflect"

class Foo {
  dynamic: Dynamic = new {
    hello = "world"
    ["hello"] = "world"
    "hello world"
  }
  string: String = "foo"
  map = Map("foo", "bar")
  mapping: Mapping = new { ["foo"] = "bar" }
  list = List("foo", "bar")
  listing: Listing = new { "foo"; 0 }
  set = Set("foo", "bar")
  duration = 123.h
  dataSize = 123.gib
  pair = Pair("foo", "bar")
  intSeq = IntSeq(123, 456)
  regex = Regex("foo.*")
  func: ((String, Int) -> Boolean)? =
    (a, b) -> a.sha256Int + b % 2 == 0
  bytes = Bytes(0x01, 0x02, 0x03)
  moduleClass: Class?
  classClass: Class? = Foo
  typealiasInstance: TypeAlias? = Bar
}

typealias Bar = Mapping<String, String>

classInstance: Foo = new {
  moduleClass = module.getClass()
}

hidden noFunc: Foo = (classInstance) { func = null }

hidden encoded: Bytes = new encoding.PklBinaryEncodingRenderer {}.renderValue(noFunc)

output {
  bytes = encoded
}
