// test scenarios that put type constraints in Reference type nodes (annotations/casts)

import "pkl:test"
import "pkl:ref"

class D extends ref.Domain
typealias Ref<T> = ref.Reference<D, T>
local d: D = new {}

// foo = test.catch(() -> ref.Reference(d, String, "") as ref.Reference<D, String(true)>)
foo = test.catch(() -> ref.Reference(d, String, "") as Ref<String(true)>)
bar = test.catch(() -> ref.Reference(d, String, "") as Ref<String(true) | Int>)
baz = test.catch(() -> ref.Reference(d, String, "") as Ref<Listing<String(true)>>)
qux = test.catch(() -> ref.Reference(d, String, "") as Ref<Alias1?>)

typealias Alias1 = Int | Alias2?
typealias Alias2 = String(length < 5)
