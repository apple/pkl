res3 =
  let (qux = 1)
  let (
    x = new Listing {
      for (num in List(1, 2)) {
        qux + num
      }
    }
  )
  let (y = 5)
  let (
    z = new Listing {
      for (nummm in List(1, 2)) {
        when (qux + y == nummm) {
          nummm + y
        }
      }
    }
  )
    new { ...x; ...z }

res4 = 
